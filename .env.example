# =============================================================================
# API Gateway - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# The setup script (scripts/setup-local.sh) will auto-generate secrets.
#
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Superuser credentials (used for database initialization only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432

# Kong database user
KONG_PG_USER=kong
KONG_PG_PASSWORD=change_me_kong
KONG_PG_DATABASE=kong

# Admin panel database user
ADMIN_DB_USER=api_gateway_admin
ADMIN_DB_PASSWORD=change_me_admin
ADMIN_DB_NAME=api_gateway_admin
# For production: set ADMIN_DB_HOST to the managed database hostname
# ADMIN_DB_HOST=postgres

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6380
# For production: set REDIS_HOST to the managed Redis hostname
# REDIS_HOST=redis

# -----------------------------------------------------------------------------
# Kong Gateway
# -----------------------------------------------------------------------------
KONG_PROXY_PORT=8000
KONG_PROXY_SSL_PORT=8443
KONG_ADMIN_PORT=8001

# -----------------------------------------------------------------------------
# Admin Panel (FastAPI)
# -----------------------------------------------------------------------------
ADMIN_PANEL_PORT=8080

# Application secret key (used for JWT signing, session encryption)
# MUST be changed in production. Generate with: openssl rand -hex 32
SECRET_KEY=change_me_secret_key

# JWT token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Environment identifier
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Monitoring - Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Monitoring - Grafana
# -----------------------------------------------------------------------------
GRAFANA_PORT=3200
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# For production:
# GRAFANA_ROOT_URL=https://grafana.api-gateway.example.com

# -----------------------------------------------------------------------------
# Cribl Stream
# -----------------------------------------------------------------------------
CRIBL_PORT=9420
CRIBL_SYSLOG_PORT=5140

# -----------------------------------------------------------------------------
# AI / Claude
# -----------------------------------------------------------------------------
# Default provider is anthropic_foundry (Azure AI Foundry).
# Set AI_PROVIDER=claude to use the direct Anthropic API instead.
AI_PROVIDER=anthropic_foundry

# API key -- used by both providers. Set AZURE_AI_FOUNDRY_API_KEY to use a
# separate key for foundry; otherwise ANTHROPIC_API_KEY is used for both.
ANTHROPIC_API_KEY=

# Azure AI Foundry settings (required when AI_PROVIDER=anthropic_foundry)
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
ANTHROPIC_MODEL=cogdep-aifoundry-dev-eus2-claude-sonnet-4-5

# For direct Anthropic API, uncomment and set:
# AI_PROVIDER=claude
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Cost and sampling controls
AI_MAX_COST_PER_ANALYSIS=0.50
AI_SAMPLING_RATE=0.1

# -----------------------------------------------------------------------------
# Authentication (OIDC)
# -----------------------------------------------------------------------------
# For LOCAL DEVELOPMENT: uses the built-in mock OIDC provider (mock-oidc service).
# No Entra ID credentials needed -- just use the defaults below.
#
# For PRODUCTION: comment out OIDC_DISCOVERY_URL and set Entra ID values.
# -----------------------------------------------------------------------------

# Mock OIDC provider (local dev) -- comment this line for production
OIDC_DISCOVERY_URL=http://mock-oidc:8080/.well-known/openid-configuration
MOCK_OIDC_PORT=8180

# Client credentials (mock defaults for local dev)
ENTRA_CLIENT_ID=api-gateway-local
ENTRA_CLIENT_SECRET=mock-client-secret
ENTRA_REDIRECT_URI=http://localhost:8080/auth/callback

# Entra ID (production) -- uncomment and fill in for real Azure AD
# ENTRA_TENANT_ID=your-tenant-id
# ENTRA_CLIENT_ID=your-app-registration-client-id
# ENTRA_CLIENT_SECRET=your-client-secret
# ENTRA_REDIRECT_URI=https://api-admin.yourcompany.com/auth/callback

# -----------------------------------------------------------------------------
# OWASP ZAP Security Scanner
# -----------------------------------------------------------------------------
# Scan mode: "passive" (spider + passive rules only) or "active" (includes
# attack-pattern testing -- only use in non-production environments)
ZAP_SCAN_MODE=passive

# How often to run scan cycles (minutes)
ZAP_SCAN_INTERVAL_MINUTES=5

# Host ports for ZAP services
ZAP_API_PORT=8280
ZAP_PROXY_PORT=8290
ZAP_EXPORTER_PORT=9290

# Log level for the ZAP exporter service
ZAP_LOG_LEVEL=INFO

# Cribl Stream endpoint for forwarding ZAP findings
# (uses the existing Cribl HTTP input on port 9081)
CRIBL_STREAM_URL=http://cribl:9081/api/v1/zap
CRIBL_STREAM_TOKEN=

# -----------------------------------------------------------------------------
# Azure Container Registry (CI/CD only)
# -----------------------------------------------------------------------------
# ACR_REGISTRY=youracr.azurecr.io
# IMAGE_TAG=latest
