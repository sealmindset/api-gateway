# =============================================================================
# API Gateway - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# The setup script (scripts/setup-local.sh) will auto-generate secrets.
#
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Superuser credentials (used for database initialization only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432

# Kong database user
KONG_PG_USER=kong
KONG_PG_PASSWORD=change_me_kong
KONG_PG_DATABASE=kong

# Admin panel database user
ADMIN_DB_USER=api_gateway_admin
ADMIN_DB_PASSWORD=change_me_admin
ADMIN_DB_NAME=api_gateway_admin
# For production: set ADMIN_DB_HOST to the managed database hostname
# ADMIN_DB_HOST=postgres

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6380
# For production: set REDIS_HOST to the managed Redis hostname
# REDIS_HOST=redis

# -----------------------------------------------------------------------------
# Kong Gateway
# -----------------------------------------------------------------------------
KONG_PROXY_PORT=8000
KONG_PROXY_SSL_PORT=8443
KONG_ADMIN_PORT=8001

# -----------------------------------------------------------------------------
# Admin Panel (FastAPI)
# -----------------------------------------------------------------------------
ADMIN_PANEL_PORT=8080

# Application secret key (used for JWT signing, session encryption)
# MUST be changed in production. Generate with: openssl rand -hex 32
SECRET_KEY=change_me_secret_key

# JWT token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Environment identifier
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Monitoring - Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Monitoring - Grafana
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# For production:
# GRAFANA_ROOT_URL=https://grafana.api-gateway.example.com

# -----------------------------------------------------------------------------
# Cribl Stream
# -----------------------------------------------------------------------------
CRIBL_PORT=9420
CRIBL_SYSLOG_PORT=5140

# -----------------------------------------------------------------------------
# Azure Container Registry (CI/CD only)
# -----------------------------------------------------------------------------
# ACR_REGISTRY=youracr.azurecr.io
# IMAGE_TAG=latest
