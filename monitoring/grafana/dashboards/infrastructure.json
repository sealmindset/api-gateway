        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_spec_cpu_quota{container=\"kong\", pod=~\"$pod\"} / container_spec_cpu_period{container=\"kong\", pod=~\"$pod\"}",
