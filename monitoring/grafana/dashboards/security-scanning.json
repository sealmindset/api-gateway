          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "alert_name": "Vulnerability", "severity": "Severity", "owasp_category": "OWASP Category", "Value": "Count" } } }
