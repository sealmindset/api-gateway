# =============================================================================
# .gitignore - API Gateway
# =============================================================================

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.p12
secrets/

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
terraform/.terraform/
terraform/**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.coverage
htmlcov/
*.cover
.mypy_cache/
.ruff_cache/
.venv/
venv/
ENV/

# -----------------------------------------------------------------------------
# Node.js (if any frontend tooling)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
coverage.xml
test-results.xml
results.sarif
trivy-*.sarif

# -----------------------------------------------------------------------------
# Data volumes (local development)
# -----------------------------------------------------------------------------
data/
